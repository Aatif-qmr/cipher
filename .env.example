# Exchange
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET=your_binance_secret_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
QNT_TELEGRAM_TOKEN=your_telegram_bot_token_here
QNT_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Freqtrade Web UI (used across all bot instances)
FREQTRADE_UI_USERNAME=your_username_here
FREQTRADE_UI_PASSWORD=your_strong_password_here

# Freqtrade JWT secret — generate with: openssl rand -hex 32
FT_JWT_SECRET_KEY=generate_with_openssl_rand_hex_32

# PostgreSQL DSN per strategy (used in live/dry_run via supervisord)
FREQTRADE_DB_MEANREVERSIONV1=postgresql://user:pass@localhost/cipher_mean_reversion
FREQTRADE_DB_SCALPV1=postgresql://user:pass@localhost/cipher_scalp
FREQTRADE_DB_TRENDFOLLOWV1=postgresql://user:pass@localhost/cipher_trend_follow
FREQTRADE_DB_SWINGV1=postgresql://user:pass@localhost/cipher_swing
FREQTRADE_DB_DAILYTRENDV1=postgresql://user:pass@localhost/cipher_daily
FREQTRADE_DB_MICROSCALPV1=postgresql://user:pass@localhost/cipher_micro

# Tailscale / multi-machine setup
M1_TAILSCALE_IP=your_m1_tailscale_ip
M2_TAILSCALE_IP=your_m2_tailscale_ip
M2_SSH_USER=your_m2_username
M2_HMM_PATH=/Users/your_m2_username/cipher/qnt/oracle/hmm_model.pkl

# Sentiment Sources
CRYPTOPANIC_API_KEY=get_free_from_cryptopanic.com
COINGECKO_API_KEY=your_coingecko_key_here

# Risk thresholds (override defaults if needed)
DXY_THRESHOLD_PCT=1.0
